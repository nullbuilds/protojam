; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ProtoJam"
run/main_scene="uid://omcwv6fpn2mn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

AudioManager="*uid://bdys4448gq7vu"
MouseModeManager="*uid://c87fsy7qsxm6n"

[debug]

gdscript/warnings/directory_rules={
"res://addons": 1
}

[display]

window/size/viewport_width=256
window/size/viewport_height=224
window/size/window_width_override=1024
window/size/window_height_override=896
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/proto_jam/audio/plugin.cfg", "res://addons/proto_jam/background_loader/plugin.cfg", "res://addons/proto_jam/credits/plugin.cfg", "res://addons/proto_jam/damage/plugin.cfg", "res://addons/proto_jam/input/plugin.cfg", "res://addons/proto_jam/materials/plugin.cfg", "res://addons/proto_jam/plugin.cfg", "res://addons/proto_jam/plugin_helper/plugin.cfg", "res://addons/proto_jam/props/plugin.cfg", "res://addons/proto_jam/save/plugin.cfg", "res://addons/proto_jam/settings/plugin.cfg", "res://addons/proto_jam/state_machine/plugin.cfg", "res://addons/proto_jam/transition/plugin.cfg", "res://addons/proto_jam/utils/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
